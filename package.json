{
  "name": "noir-launcher",
  "version": "0.2.0",
  "private": true,
  "main": "dist/apps/desktop-electron/src/main.js",
  "scripts": {
    "dev:ui": "vite --config apps/desktop/vite.config.ts",
    "dev:shell": "npm run build:node && node scripts/run-electron-dev.mjs",
    "build:desktop": "vite build --config apps/desktop/vite.config.ts",
    "build:node": "tsc -p tsconfig.node.json",
    "build": "npm run build:desktop && npm run build:node",
    "check": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "npm run build:node && node --test tests/*.test.mjs",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "adm-zip": "^0.5.12",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.0",
    "fs-extra": "^11.2.0",
    "keytar": "^7.9.0",
    "minecraft-launcher-core": "^3.17.0",
    "node-fetch": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tar": "^7.5.11",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/tar": "^6.1.13",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^41.0.2",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^8.0.0"
  }
}
