#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${REAL_NPM_NODE:-}" || -z "${REAL_NPM_CLI:-}" ]]; then
  echo "REAL_NPM_NODE/REAL_NPM_CLI nao configurados" >&2
  exit 1
fi

args=()
for arg in "$@"; do
  if [[ "$arg" == "--prod" ]]; then
    args+=("--omit=dev")
  else
    args+=("$arg")
  fi
done

exec "$REAL_NPM_NODE" "$REAL_NPM_CLI" "${args[@]}"

