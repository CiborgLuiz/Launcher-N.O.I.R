{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "apps/desktop-electron/src/**/*.ts",
    "packages/auth/src/**/*.ts",
    "packages/core/src/**/*.ts",
    "packages/curseforge/src/**/*.ts",
    "packages/instance-manager/src/**/*.ts",
    "packages/launcher-runtime/src/**/*.ts",
    "packages/shared/src/**/*.ts",
    "packages/updater/src/**/*.ts"
  ]
}
