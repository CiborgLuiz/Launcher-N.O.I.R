# Microsoft OAuth configuration
# Optional: if omitted, MSMC falls back to the default Microsoft launcher app token.
MICROSOFT_CLIENT_ID=

# Option A: full redirect URI
# Keep this aligned with your custom Microsoft app registration when MICROSOFT_CLIENT_ID is set.
MS_REDIRECT_URI=http://127.0.0.1:53682/callback

# Option B (if MS_REDIRECT_URI not set):
# MS_REDIRECT_HOST=127.0.0.1
# MS_REDIRECT_PORT=53682

# CurseForge API
CURSEFORGE_API_KEY=

# Optional updater configuration
# GITHUB_RELEASES_REPO=owner/repository

# Development only
NOIR_ENABLE_DEV_OFFLINE=true
